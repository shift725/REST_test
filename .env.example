# =============================================================================
# 將此檔複製為 .env 後填值；.env 已在 .gitignore，不會被 commit
#   cp .env.example .env
# =============================================================================

# ----- Django -----
# 產生：python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-secure-random-string-50-chars-or-more

# 'True' / 'False'（Python bool 字串）
DEBUG=False

# 逗號分隔；本機可用 localhost,127.0.0.1；上 TLS 後改成你的網域
ALLOWED_HOSTS=localhost,127.0.0.1

# ----- PostgreSQL -----
# 這四個值會被 db service 用來初始化資料庫，並由 compose 組合成 DATABASE_URL 注入 web
POSTGRES_USER=resttest
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=resttest
DB_HOST=db
DB_PORT=5432

# ----- Web -----
# 主機端對外的 port；容器內固定 8000
WEB_PORT=8000

# ----- Superuser bootstrap（選填）-----
# 三個欄位都填才會在容器啟動時自動建立 superuser；已存在則跳過。任一空白則完全不建立。
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-admin-password

# ----- TLS（僅 `docker compose --profile tls up` 時用到）-----
DOMAIN_NAME=example.com
CERTBOT_EMAIL=you@example.com
